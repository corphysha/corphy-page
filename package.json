{
  "name": "corphy-page",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/",
    "check:ci": "biome ci src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,mjs,cjs}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{astro,css,json,md,mjs}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
