---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import "@/styles/blog.css";

const allPosts = await getCollection("blog", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Simple client-side pagination — all posts shown, no server pagination needed for small blogs
const pageTitle = "Blog";
const pageDesc = "Thoughts, tutorials, and updates from Corphy.";
---

<Layout>
  <main class="blog-post">
    <a href="/corphy-page/" class="blog-back">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5"/>
        <path d="M12 19l-7-7 7-7"/>
      </svg>
      Back to Home
    </a>

    <header class="blog-post-header">
      <h1 class="blog-post-title">{pageTitle}</h1>
      <p class="blog-post-desc">{pageDesc}</p>
    </header>

    {
      posts.length === 0 ? (
        <div class="blog-empty">
          <span class="blog-empty-icon">📝</span>
          <p>No posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => {
            const wordCount = post.body?.split(/\s+/).length ?? 0;
            const readingTime = Math.max(1, Math.ceil(wordCount / 200));
            return (
              <article class="blog-card">
                <h2 class="blog-card-title">
                  <a href={`/corphy-page/blog/${post.id}/`}>{post.data.title}</a>
                </h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <div class="blog-card-meta">
                  <time class="blog-card-date" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                  <span class="reading-time">· {readingTime} min read</span>
                  {post.data.tags.length > 0 && (
                    <div class="blog-card-tags">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <a
                          href={`/corphy-page/blog/tags/${tag.toLowerCase()}/`}
                          class="blog-card-tag"
                        >
                          {tag}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      )
    }
  </main>
</Layout>
