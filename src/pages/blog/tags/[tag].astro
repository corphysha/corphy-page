---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import "@/styles/blog.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tags.add(tag.toLowerCase());
    }
  }
  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allPosts = await getCollection("blog", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const posts = allPosts
  .filter((p) => p.data.tags.some((t) => t.toLowerCase() === tag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
  <main class="blog-list-header">
    <a href="/corphy-page/blog/" class="blog-back">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5"/>
        <path d="M12 19l-7-7 7-7"/>
      </svg>
      Back to Blog
    </a>

    <header class="blog-post-header">
      <h1 class="blog-post-title">#{tag}</h1>
      <p class="blog-post-desc">{posts.length} post{posts.length !== 1 ? "s" : ""} tagged with "{tag}"</p>
    </header>

    {
      posts.length === 0 ? (
        <div class="blog-empty">
          <span class="blog-empty-icon">🏷️</span>
          <p>No posts found for this tag.</p>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => {
            const wordCount = post.body?.split(/\s+/).length ?? 0;
            const readingTime = Math.max(1, Math.ceil(wordCount / 200));
            return (
              <article class="blog-card">
                <h2 class="blog-card-title">
                  <a href={`/corphy-page/blog/${post.id}/`}>{post.data.title}</a>
                </h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <div class="blog-card-meta">
                  <time class="blog-card-date" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                  <span>{readingTime} min read</span>
                </div>
              </article>
            );
          })}
        </div>
      )
    }
  </main>
</Layout>
