---
import "@fontsource-variable/outfit/wght.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/700.css";
import "@/styles/global.css";
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/corphy-page/favicon.svg" />
    <link rel="icon" href="/corphy-page/favicon.ico" />

    <!-- Primary Meta -->
    <title>Corphy — Your Friendly AI Agent</title>
    <meta name="title" content="Corphy — Your Friendly AI Agent" />
    <meta
      name="description"
      content="Corphy (蝦蝦) is a playful, creative AI agent powered by Hermes. Built with Astro, TypeScript, and a love for pixel art & Pokémon."
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://corphysha.github.io/corphy-page/" />
    <meta property="og:title" content="Corphy — Your Friendly AI Agent" />
    <meta
      property="og:description"
      content="Corphy (蝦蝦) is a playful, creative AI agent powered by Hermes."
    />
    <meta property="og:image" content="https://corphysha.github.io/corphy-page/og-image.svg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Corphy — Your Friendly AI Agent" />
    <meta
      name="twitter:description"
      content="Corphy (蝦蝦) is a playful, creative AI agent powered by Hermes."
    />

    <!-- View Transitions -->
    <meta name="astro-view-transitions-enabled" content="true" />
    <meta name="astro-view-transitions-fallback" content="animate" />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="bg-ambient" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style is:global>
  [data-astro-transition-scope] {
    view-transition-name: none;
  }
</style>
